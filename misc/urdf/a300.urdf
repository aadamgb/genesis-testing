<?xml version="1.0" ?>

<robot name="a300">

  <properties mass="1.21" arm="0.15" kf="4.5e-8" km="5.4e-10" thrust2weight="6.944"  max_speed_kmh="200" gnd_eff_coeff="11.36859" prop_radius="0.089" drag_coeff_xy="9.1785e-7" drag_coeff_z="10.311e-7" dw_coeff_1="2267.18" dw_coeff_2=".16" dw_coeff_3="-.11" />

  <link name="base_link"> 

    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="1.21"/>
      <inertia ixx=".007" ixy="0.0" ixz="0.0" iyy=".007" iyz="0.0" izz=".01"/>
    </inertial>

    <visual>
      <origin rpy="0 0 55" xyz="0 0 0.075"/>
      <geometry>
        <mesh filename="./mesh/a300/frame.stl" scale="0.001 0.001 0.001"/>
      </geometry> 
      <material name="frame">
        <color rgba="0.2 0.2 0.2 1"/>
      </material> 
    </visual>

    <visual>
      <origin rpy="0 0 55" xyz="0.106 -0.106 0.075"/>
      <geometry>
        <mesh filename="./mesh/a300/motor.stl" scale="0.001 0.001 0.001"/>
      </geometry> 
      <material name="motor">
        <color rgba="0 .0 .0 1"/>
      </material> 
    </visual>
    <visual>
      <origin rpy="0 0 55" xyz="-0.106 0.106 0.075"/>
      <geometry>
        <mesh filename="./mesh/a300/motor.stl" scale="0.001 0.001 0.001"/>
      </geometry> 
      <material name="motor">
        <color rgba="0 .0 .0 1"/>
      </material> 
    </visual>
    <visual>
      <origin rpy="0 0 55" xyz="0.106 0.106 0.075"/>
      <geometry>
        <mesh filename="./mesh/a300/motor.stl" scale="0.001 0.001 0.001"/>
      </geometry> 
      <material name="motor">
        <color rgba="0 .0 .0 1"/>
      </material> 
    </visual>
    <visual>
      <origin rpy="0 0 55" xyz="-0.106 -0.106 0.075"/>
      <geometry>
        <mesh filename="./mesh/a300/motor.stl" scale="0.001 0.001 0.001"/>
      </geometry> 
      <material name="motor">
        <color rgba="0 .0 .0 1"/>
      </material> 
    </visual>


<!-- Added 4 Cylindrical Legs -->
    <visual>
      <origin rpy="0 0 0" xyz="0.106 -0.106 -0.03"/>
      <geometry>
        <cylinder radius="0.015" length="0.06"/>
      </geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="-0.106 0.106 -0.03"/>
      <geometry>
        <cylinder radius="0.015" length="0.06"/>
      </geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="0.106 0.106 -0.03"/>
      <geometry>
        <cylinder radius="0.015" length="0.06"/>
      </geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
    <visual>
      <origin rpy="0 0 0" xyz="-0.106 -0.106 -0.03"/>
      <geometry>
        <cylinder radius="0.015" length="0.06"/>
      </geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>


    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder radius=".06" length=".025"/>
      </geometry>
    </collision>  

  </link>

  <link name="prop0_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0.106 -0.106 0"/>
      <mass value="0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.106 -0.106 0.02"/>
      <geometry>
          <mesh filename="./mesh/a300/prop.dae"  scale="0.4 0.4 0.4"/>
      </geometry> 
    </visual>
  </link>
  <joint name="prop0_joint" type="fixed">
    <parent link="base_link"/>
    <child link="prop0_link"/>
  </joint>

  <link name="prop1_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.106 0.106 0"/>
